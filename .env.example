# Application
APP_NAME=Wedding Invitation System
APP_ENV=production
SECRET_KEY=change-this-to-a-very-long-random-secret-key-at-least-32-chars
QR_HMAC_SECRET=another-very-long-random-secret-for-qr-code-signing

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wedding_db
DB_USER=wedding_user
DB_PASSWORD=strong_db_password_here

# JWT
JWT_SECRET_KEY=yet-another-long-random-secret-for-jwt-tokens
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
